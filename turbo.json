{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", ".svelte-kit/**", "build/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "watch:types": {
      "cache": false,
      "persistent": true
    },
    "generate:types": {
      "cache": false,
      "outputs": ["../../packages/payload-types/src/index.ts"]
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "lint": {
      "dependsOn": ["^build"]
    }
  }
}
